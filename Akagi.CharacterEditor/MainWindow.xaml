<Window x:Class="Akagi.CharacterEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:nodify="clr-namespace:Nodify;assembly=Nodify"
        xmlns:local="clr-namespace:Akagi.CharacterEditor"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="MainWindow" Width="1920" Height="1080"
        Background="Black">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <local:CollectionCountToVisibilityConverter x:Key="CollectionCountToVisibilityConverter"/>
        <local:CollectionHasItemsToVisibilityConverter x:Key="CollectionHasItemsToVisibilityConverter"/>
        <local:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
        <local:CollectionCountToGridLengthConverter x:Key="CollectionCountToGridLengthConverter"/>
        <local:TypeColorConverter x:Key="TypeColorConverter"/>
        <local:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <local:SnapToGridConverter x:Key="SnapToGridConverter"/>

        <!-- Grid Background Resources -->
        <SolidColorBrush x:Key="GridLinesBrush" Color="#1A1A1A"/>
        
        <GeometryDrawing x:Key="SmallGridGeometry"
                         Geometry="M0,0 L0,1 0.03,1 0.03,0.03 1,0.03 1,0 Z"
                         Brush="{StaticResource GridLinesBrush}" />

        <GeometryDrawing x:Key="LargeGridGeometry"
                         Geometry="M0,0 L0,1 0.015,1 0.015,0.015 1,0.015 1,0 Z"
                         Brush="{StaticResource GridLinesBrush}" />

        <DrawingBrush x:Key="SmallGridLinesDrawingBrush"
                      TileMode="Tile"
                      ViewportUnits="Absolute"
                      Viewport="0 0 20 20"
                      Transform="{Binding ViewportTransform, ElementName=Editor}"
                      Drawing="{StaticResource SmallGridGeometry}" />

        <DrawingBrush x:Key="LargeGridLinesDrawingBrush"
                      TileMode="Tile"
                      ViewportUnits="Absolute"
                      Opacity="0.5"
                      Viewport="0 0 100 100"
                      Transform="{Binding ViewportTransform, ElementName=Editor}"
                      Drawing="{StaticResource LargeGridGeometry}" />

        <!-- MenuItem Style -->
        <Style x:Key="ThemedMenuItem" TargetType="MenuItem">
            <Setter Property="Foreground" Value="{DynamicResource NodifyEditor.ForegroundBrush}"/>
            <Setter Property="Background" Value="{DynamicResource NodifyEditor.BackgroundBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Node.BackgroundBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ComboBox Style -->
        <Style x:Key="ThemedComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource Node.BackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource NodifyEditor.ForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource NodifyEditor.SelectionRectangleStroke}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Name="ToggleButton"
                                        Grid.Column="2"
                                        Focusable="false"
                                        IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                        ClickMode="Press"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition Width="20"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Name="ContentSite"
                                                    Grid.Column="0"
                                                    IsHitTestVisible="False"
                                                    Content="{TemplateBinding SelectionBoxItem}"
                                                    ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                    ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                    Margin="3,3,3,3"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Left">
                                        <ContentPresenter.Resources>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource NodifyEditor.ForegroundBrush}"/>
                                            </Style>
                                        </ContentPresenter.Resources>
                                    </ContentPresenter>
                                    <Path Grid.Column="1"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Data="M 0 0 L 4 4 L 8 0 Z"
                                        Fill="{DynamicResource NodifyEditor.ForegroundBrush}"/>
                                </Grid>
                            </ToggleButton>
                            <Popup Name="Popup"
                                Placement="Bottom"
                                IsOpen="{TemplateBinding IsDropDownOpen}"
                                AllowsTransparency="True"
                                Focusable="False"
                                PopupAnimation="Slide">
                                <Grid Name="DropDown"
                                    SnapsToDevicePixels="True"
                                    MinWidth="{TemplateBinding ActualWidth}"
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border Name="DropDownBorder"
                                        Background="{DynamicResource NodifyEditor.BackgroundBrush}"
                                        BorderThickness="1"
                                        BorderBrush="{DynamicResource NodifyEditor.SelectionRectangleStroke}"/>
                                    <ScrollViewer Margin="4,6,4,6" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBoxItem Style -->
        <Style x:Key="ThemedComboBoxItem" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="{DynamicResource NodifyEditor.BackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource NodifyEditor.ForegroundBrush}"/>
            <Setter Property="Padding" Value="3,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter>
                                <ContentPresenter.Resources>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ComboBoxItem}}"/>
                                    </Style>
                                </ContentPresenter.Resources>
                            </ContentPresenter>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource Node.BackgroundBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource Node.BackgroundBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TreeViewItem Style -->
        <Style x:Key="ThemedTreeViewItem" TargetType="TreeViewItem">
            <Setter Property="Foreground" Value="{DynamicResource NodifyEditor.ForegroundBrush}"/>
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsAbstract}" Value="True">
                    <Setter Property="Foreground" Value="Gray"/>
                    <Setter Property="FontStyle" Value="Italic"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsVisible}" Value="False">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid x:Name="MainGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" MinWidth="150" MaxWidth="400"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="{Binding SelectedTab.EditorViewModel.SelectedNodes.Count, Converter={StaticResource CollectionCountToGridLengthConverter}}" MinWidth="0" MaxWidth="400"/>
        </Grid.ColumnDefinitions>

        <Menu Grid.Row="0" Grid.ColumnSpan="5"
              Background="{DynamicResource NodifyEditor.BackgroundBrush}"
              Foreground="{DynamicResource NodifyEditor.ForegroundBrush}">
            <MenuItem Header="_File"
                      Style="{StaticResource ThemedMenuItem}">
                <MenuItem Header="_New" 
                          Command="{Binding NewCommand}"
                          InputGestureText="Ctrl+N"
                          Style="{StaticResource ThemedMenuItem}" />
                <MenuItem Header="_Open..." 
                          Command="{Binding OpenCommand}"
                          InputGestureText="Ctrl+O"
                          Style="{StaticResource ThemedMenuItem}" />
                <MenuItem Header="Open _Recent"
                          Style="{StaticResource ThemedMenuItem}"
                          ItemsSource="{Binding RecentFiles}">
                    <MenuItem.ItemContainerStyle>
                        <Style TargetType="MenuItem" BasedOn="{StaticResource ThemedMenuItem}">
                            <Setter Property="Header" Value="{Binding}"/>
                            <Setter Property="Command" Value="{Binding DataContext.OpenRecentFileCommand, RelativeSource={RelativeSource AncestorType=Menu}}"/>
                            <Setter Property="CommandParameter" Value="{Binding}"/>
                            <Setter Property="ToolTip" Value="{Binding}"/>
                        </Style>
                    </MenuItem.ItemContainerStyle>
                </MenuItem>
                <Separator/>
                <MenuItem Header="_Save" 
                          Command="{Binding SaveCommand}"
                          InputGestureText="Ctrl+S"
                          Style="{StaticResource ThemedMenuItem}" />
                <MenuItem Header="Save _As..." 
                          Command="{Binding SaveAsCommand}"
                          InputGestureText="Ctrl+Shift+S"
                          Style="{StaticResource ThemedMenuItem}" />
            </MenuItem>
            <MenuItem Header="_Edit"
                      Style="{StaticResource ThemedMenuItem}">
                <MenuItem Header="_Undo" 
                          Command="{Binding SelectedTab.EditorViewModel.UndoCommand}"
                          InputGestureText="Ctrl+Z"
                          Style="{StaticResource ThemedMenuItem}" />
                <MenuItem Header="_Redo" 
                          Command="{Binding SelectedTab.EditorViewModel.RedoCommand}"
                          InputGestureText="Ctrl+Y"
                          Style="{StaticResource ThemedMenuItem}" />
                <Separator/>
                <MenuItem Header="_Copy" 
                          Command="{Binding SelectedTab.EditorViewModel.CopyNodesCommand}"
                          InputGestureText="Ctrl+C"
                          Style="{StaticResource ThemedMenuItem}" />
                <MenuItem Header="_Paste" 
                          Command="{Binding SelectedTab.EditorViewModel.PasteNodesCommand}"
                          InputGestureText="Ctrl+V"
                          Style="{StaticResource ThemedMenuItem}" />
            </MenuItem>
            <MenuItem Header="_View"
                      Style="{StaticResource ThemedMenuItem}">
                <MenuItem Header="Snap to Grid" 
                          IsCheckable="True"
                          IsChecked="{Binding SnapToGrid}"
                          Style="{StaticResource ThemedMenuItem}" />
            </MenuItem>
            <MenuItem Header="_Debug"
                      Style="{StaticResource ThemedMenuItem}">
                <MenuItem Header="Print Debug Info" 
                          Command="{Binding SelectedTab.EditorViewModel.PrintDebugInfoCommand}"
                          Style="{StaticResource ThemedMenuItem}" />
            </MenuItem>
        </Menu>

        <!-- Tab Control -->
        <TabControl Grid.Row="1" Grid.ColumnSpan="5"
                    ItemsSource="{Binding Tabs}"
                    SelectedItem="{Binding SelectedTab}"
                    Background="{DynamicResource NodifyEditor.BackgroundBrush}"
                    BorderThickness="0,0,0,1"
                    BorderBrush="{DynamicResource NodifyEditor.ForegroundBrush}">
            <TabControl.Resources>
                <!-- TabControl Style -->
                <Style TargetType="TabControl">
                    <Setter Property="Background" Value="{DynamicResource NodifyEditor.BackgroundBrush}"/>
                </Style>
                
                <!-- TabItem Style -->
                <Style TargetType="TabItem">
                    <Setter Property="Background" Value="{DynamicResource NodifyEditor.BackgroundBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource NodifyEditor.ForegroundBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource NodifyEditor.ForegroundBrush}"/>
                    <Setter Property="BorderThickness" Value="1,1,1,0"/>
                    <Setter Property="Padding" Value="10,5"/>
                    <Setter Property="Margin" Value="0,0,2,0"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border Name="Border"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="3,3,0,0"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter ContentSource="Header"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="{DynamicResource Node.BackgroundBrush}"/>
                                        <Setter Property="Panel.ZIndex" Value="100"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#30FFFFFF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>
            <TabControl.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding TabHeader}" 
                                   Foreground="{DynamicResource NodifyEditor.ForegroundBrush}"
                                   VerticalAlignment="Center"/>
                        <Button Content="×" 
                                Command="{Binding CloseCommand}"
                                CommandParameter="{Binding}"
                                Margin="8,0,0,0"
                                Padding="4,0"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="{DynamicResource NodifyEditor.ForegroundBrush}"
                                FontSize="16"
                                FontWeight="Bold"
                                VerticalAlignment="Center"
                                Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#40FFFFFF"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </DataTemplate>
            </TabControl.ItemTemplate>
            <TabControl.ContentTemplate>
                <DataTemplate>
                    <!-- Tab content is defined below in the main grid -->
                    <Grid/>
                </DataTemplate>
            </TabControl.ContentTemplate>
        </TabControl>

        <!-- Node Library Panel -->
        <Border Grid.Row="2" Grid.Column="0"
                BorderBrush="{DynamicResource NodifyEditor.ForegroundBrush}" 
                BorderThickness="0,0,2,0" 
                Background="{DynamicResource NodifyEditor.BackgroundBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" 
                           Text="Node Library" 
                           FontWeight="Bold" 
                           Margin="10" 
                           FontSize="14"
                           Foreground="{DynamicResource NodifyEditor.ForegroundBrush}"/>

                <Grid Grid.Row="1" Margin="10,0,10,10">
                    <TextBox Text="{Binding SelectedTab.EditorViewModel.NodeLibrary.SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Background="{DynamicResource Node.BackgroundBrush}"
                             Foreground="{DynamicResource NodifyEditor.ForegroundBrush}"
                             BorderBrush="{DynamicResource NodifyEditor.SelectionRectangleStroke}"/>
                    <TextBlock Text="Search nodes..."
                               IsHitTestVisible="False"
                               Margin="5,2,0,0"
                               Foreground="Gray">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedTab.EditorViewModel.NodeLibrary.SearchText}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <TreeView Grid.Row="2"
                          ItemsSource="{Binding SelectedTab.EditorViewModel.NodeLibrary.NodeTypes}"
                          Background="{DynamicResource NodifyEditor.BackgroundBrush}"
                          BorderThickness="0"
                          Margin="10,0,10,10"
                          MouseDoubleClick="NodeLibraryTreeView_MouseDoubleClick"
                          MouseMove="NodeLibraryTreeView_MouseMove"
                          PreviewMouseLeftButtonDown="NodeLibraryTreeView_PreviewMouseLeftButtonDown">
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem" BasedOn="{StaticResource ThemedTreeViewItem}"/>
                    </TreeView.ItemContainerStyle>
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                            <Border BorderThickness="2,0,0,0" 
                                    BorderBrush="{Binding BaseTypeName, Converter={StaticResource TypeColorConverter}}"
                                    Padding="5,2,2,2"
                                    ToolTip="{Binding Documentation}">
                                <TextBlock Text="{Binding DisplayName}"/>
                            </Border>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </Grid>
        </Border>

        <!-- GridSplitter for Node Library -->
        <GridSplitter Grid.Row="2" Grid.Column="1" 
                      Width="5" 
                      HorizontalAlignment="Stretch" 
                      VerticalAlignment="Stretch"
                      Background="{DynamicResource NodifyEditor.ForegroundBrush}" />

        <nodify:NodifyEditor x:Name="Editor"
                             Grid.Row="2" Grid.Column="2"
                             ItemsSource="{Binding SelectedTab.EditorViewModel.Nodes}"
                             Connections="{Binding SelectedTab.EditorViewModel.Connections}"
                             PendingConnection="{Binding SelectedTab.EditorViewModel.PendingConnection}"
                             SelectedItems="{Binding SelectedTab.EditorViewModel.SelectedNodes}"
                             DisconnectConnectorCommand="{Binding SelectedTab.EditorViewModel.DisconnectConnectorCommand}"
                             ViewportLocation="{Binding SelectedTab.ViewportLocation, Mode=TwoWay}"
                             ViewportZoom="{Binding SelectedTab.ViewportZoom, Mode=TwoWay}"
                             AllowDrop="True"
                             Drop="NodifyEditor_Drop"
                             MouseRightButtonDown="NodifyEditor_MouseRightButtonDown"
                             PreviewMouseRightButtonUp="NodifyEditor_PreviewMouseRightButtonUp"
                             Background="{StaticResource SmallGridLinesDrawingBrush}"
                             GridCellSize="{Binding SnapToGrid, Converter={StaticResource SnapToGridConverter}}">

            <nodify:NodifyEditor.ItemContainerStyle>
                <Style TargetType="{x:Type nodify:ItemContainer}">
                    <Setter Property="Location" Value="{Binding Location}" />
                    <EventSetter Event="PreviewMouseLeftButtonDown" Handler="ItemContainer_PreviewMouseLeftButtonDown" />
                    <EventSetter Event="PreviewMouseLeftButtonUp" Handler="ItemContainer_PreviewMouseLeftButtonUp" />
                </Style>
            </nodify:NodifyEditor.ItemContainerStyle>

            <nodify:NodifyEditor.ItemTemplate>
                <DataTemplate DataType="{x:Type local:NodeViewModel}">
                    <nodify:Node Header="{Binding Title}"
                                 Content="{Binding}"
                                 Input="{Binding Input}"
                                 Output="{Binding Output}"
                                 BorderBrush="{Binding BaseTypeName, Converter={StaticResource TypeColorConverter}}"
                                 BorderThickness="0,3,0,0">
                        <nodify:Node.HeaderTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" 
                                               Text="{Binding}" 
                                               VerticalAlignment="Center"
                                               Margin="0,0,5,0"/>
                                    <Border Grid.Column="1"
                                            Width="16" Height="16"
                                            Background="{DynamicResource Node.BackgroundBrush}"
                                            BorderBrush="{DynamicResource NodifyEditor.ForegroundBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            VerticalAlignment="Center"
                                            ToolTip="{Binding DataContext.Documentation, RelativeSource={RelativeSource AncestorType=nodify:Node}}"
                                            Visibility="{Binding DataContext.Documentation, RelativeSource={RelativeSource AncestorType=nodify:Node}, Converter={StaticResource NullToVisibilityConverter}}">
                                        <TextBlock Text="?" 
                                                   FontSize="11"
                                                   FontWeight="Bold"
                                                   Foreground="{DynamicResource NodifyEditor.ForegroundBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </nodify:Node.HeaderTemplate>
                        <nodify:Node.ContextMenu>
                            <ContextMenu Background="{DynamicResource NodifyEditor.BackgroundBrush}"
                                         Foreground="{DynamicResource NodifyEditor.ForegroundBrush}">
                                <MenuItem Header="Duplicate" 
                                          Command="{Binding DataContext.SelectedTab.EditorViewModel.DuplicateNodeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                          CommandParameter="{Binding}"
                                          Style="{StaticResource ThemedMenuItem}" />
                                <MenuItem Header="Delete" 
                                          Command="{Binding DataContext.SelectedTab.EditorViewModel.DeleteNodesCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                          Style="{StaticResource ThemedMenuItem}" />
                            </ContextMenu>
                        </nodify:Node.ContextMenu>
                        
                        <!-- Array Connector Groups (shown before regular inputs) -->
                        <nodify:Node.InputConnectorTemplate>
                            <DataTemplate DataType="{x:Type local:ConnectorViewModel}">
                                <nodify:NodeInput Header="{Binding Title}"
                                                  IsConnected="{Binding IsConnected}"
                                                  Anchor="{Binding Anchor, Mode=OneWayToSource}"
                                                  BorderBrush="{Binding ConnectorTypeName, Converter={StaticResource TypeColorConverter}}"
                                                  ToolTip="{Binding Documentation}" />
                            </DataTemplate>
                        </nodify:Node.InputConnectorTemplate>

                        <nodify:Node.OutputConnectorTemplate>
                            <DataTemplate DataType="{x:Type local:ConnectorViewModel}">
                                <nodify:NodeOutput Header="{Binding Title}"
                                                   IsConnected="{Binding IsConnected}"
                                                   Anchor="{Binding Anchor, Mode=OneWayToSource}"
                                                   BorderBrush="{Binding ConnectorTypeName, Converter={StaticResource TypeColorConverter}}"
                                                   ToolTip="{Binding Documentation}" />
                            </DataTemplate>
                        </nodify:Node.OutputConnectorTemplate>
                        
                        <!-- Inline Properties Content Template -->
                        <nodify:Node.ContentTemplate>
                            <DataTemplate DataType="{x:Type local:NodeViewModel}">
                                <StackPanel>
                                    <!-- Array Connector Groups -->
                                    <ItemsControl ItemsSource="{Binding ArrayGroups}"
                                                  Margin="5,5,5,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="{Binding ConnectorTypeName, Converter={StaticResource TypeColorConverter}}"
                                                        BorderThickness="2,0,0,0"
                                                        Padding="5,3"
                                                        Margin="0,2">
                                                    <StackPanel>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            
                                                            <TextBlock Grid.Column="0" 
                                                                       Text="{Binding Title}"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource NodifyEditor.ForegroundBrush}"
                                                                       VerticalAlignment="Center"
                                                                       ToolTip="{Binding Documentation}"/>
                                                            
                                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                                <Button Content="-"
                                                                        Command="{Binding DecreaseArraySizeCommand}"
                                                                        Width="20" Height="20"
                                                                        Padding="0"
                                                                        Margin="0,0,2,0"
                                                                        Background="{DynamicResource Node.BackgroundBrush}"
                                                                        Foreground="{DynamicResource NodifyEditor.ForegroundBrush}"
                                                                        BorderBrush="{DynamicResource NodifyEditor.SelectionRectangleStroke}"/>
                                                                <TextBlock Text="{Binding ArraySize}"
                                                                           MinWidth="20"
                                                                           TextAlignment="Center"
                                                                           VerticalAlignment="Center"
                                                                           Foreground="{DynamicResource NodifyEditor.ForegroundBrush}"/>
                                                                <Button Content="+"
                                                                        Command="{Binding IncreaseArraySizeCommand}"
                                                                        Width="20" Height="20"
                                                                        Padding="0"
                                                                        Margin="2,0,0,0"
                                                                        Background="{DynamicResource Node.BackgroundBrush}"
                                                                        Foreground="{DynamicResource NodifyEditor.ForegroundBrush}"
                                                                        BorderBrush="{DynamicResource NodifyEditor.SelectionRectangleStroke}"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    
                                    <!-- Regular Inline Properties -->
                                    <ItemsControl ItemsSource="{Binding InlineProperties}" 
                                                  Margin="5"
                                                  Grid.IsSharedSizeScope="True"
                                                  Visibility="{Binding InlineProperties.Count, Converter={StaticResource CollectionHasItemsToVisibilityConverter}}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="0,3,0,3">
                                                    <!-- Property Name -->
                                                    <TextBlock Text="{Binding Name}" 
                                                               VerticalAlignment="Center"
                                                               Margin="0,0,0,3"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource NodifyEditor.ForegroundBrush}"
                                                               Visibility="{Binding IsBasicCollection, Converter={StaticResource BoolToVisibilityConverter}}" />
                                                    
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" SharedSizeGroup="PropertyNames"/>
                                                            <ColumnDefinition Width="*" MinWidth="80"/>
                                                        </Grid.ColumnDefinitions>
                                                        
                                                        <!-- Property Name for non-collection types -->
                                                        <TextBlock Grid.Column="0" 
                                                                   Text="{Binding Name}" 
                                                                   VerticalAlignment="Center"
                                                                   Margin="0,0,8,0"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   Foreground="{DynamicResource NodifyEditor.ForegroundBrush}">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsBasicCollection}" Value="True">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                        
                                                        <!-- String -->
                                                        <TextBox Grid.Column="1"
                                                                 Text="{Binding StringValue, UpdateSourceTrigger=PropertyChanged}" 
                                                                 Background="{DynamicResource Node.BackgroundBrush}"
                                                                 Foreground="{DynamicResource NodifyEditor.ForegroundBrush}"
                                                                 BorderBrush="{DynamicResource NodifyEditor.SelectionRectangleStroke}"
                                                                 Padding="3,1"
                                                                 TextWrapping="Wrap"
                                                                 AcceptsReturn="True"
                                                                 MinHeight="24"
                                                                 MaxHeight="150"
                                                                 MaxWidth="800"
                                                                 VerticalScrollBarVisibility="Auto"
                                                                 Visibility="{Binding IsString, Converter={StaticResource BoolToVisibilityConverter}}" />

                                                        <!-- Boolean -->
                                                        <CheckBox Grid.Column="1"
                                                                  IsChecked="{Binding BoolValue}" 
                                                                  VerticalAlignment="Center"
                                                                  Foreground="{DynamicResource NodifyEditor.ForegroundBrush}"
                                                                  Visibility="{Binding IsBool, Converter={StaticResource BoolToVisibilityConverter}}" />

                                                        <!-- Integer -->
                                                        <TextBox Grid.Column="1"
                                                                 Text="{Binding IntValue, UpdateSourceTrigger=PropertyChanged}" 
                                                                 Background="{DynamicResource Node.BackgroundBrush}"
                                                                 Foreground="{DynamicResource NodifyEditor.ForegroundBrush}"
                                                                 BorderBrush="{DynamicResource NodifyEditor.SelectionRectangleStroke}"
                                                                 Padding="3,1"
                                                                 PreviewTextInput="NumericTextBox_PreviewTextInput"
                                                                 Visibility="{Binding IsInt, Converter={StaticResource BoolToVisibilityConverter}}" />

                                                        <!-- Double -->
                                                        <TextBox Grid.Column="1"
                                                                 Text="{Binding DoubleValue, UpdateSourceTrigger=PropertyChanged}" 
                                                                 Background="{DynamicResource Node.BackgroundBrush}"
                                                                 Foreground="{DynamicResource NodifyEditor.ForegroundBrush}"
                                                                 BorderBrush="{DynamicResource NodifyEditor.SelectionRectangleStroke}"
                                                                 Padding="3,1"
                                                                 PreviewTextInput="DecimalTextBox_PreviewTextInput"
                                                                 Visibility="{Binding IsDouble, Converter={StaticResource BoolToVisibilityConverter}}" />

                                                        <!-- Float -->
                                                        <TextBox Grid.Column="1"
                                                                 Text="{Binding FloatValue, UpdateSourceTrigger=PropertyChanged}" 
                                                                 Background="{DynamicResource Node.BackgroundBrush}"
                                                                 Foreground="{DynamicResource NodifyEditor.ForegroundBrush}"
                                                                 BorderBrush="{DynamicResource NodifyEditor.SelectionRectangleStroke}"
                                                                 Padding="3,1"
                                                                 PreviewTextInput="DecimalTextBox_PreviewTextInput"
                                                                 Visibility="{Binding IsFloat, Converter={StaticResource BoolToVisibilityConverter}}" />

                                                        <!-- Enum -->
                                                        <ComboBox Grid.Column="1"
                                                                  ItemsSource="{Binding EnumValues}"
                                                                  SelectedItem="{Binding SelectedEnumValue}"
                                                                  Style="{StaticResource ThemedComboBox}"
                                                                  ItemContainerStyle="{StaticResource ThemedComboBoxItem}"
                                                                  Visibility="{Binding IsRegularEnum, Converter={StaticResource BoolToVisibilityConverter}}" />
                                                        
                                                        <!-- Flags Enum (Multi-select) -->
                                                        <ListBox Grid.Column="1"
                                                                 ItemsSource="{Binding FlagsEnumItems}"
                                                                 Background="{DynamicResource Node.BackgroundBrush}"
                                                                 BorderBrush="{DynamicResource NodifyEditor.SelectionRectangleStroke}"
                                                                 BorderThickness="1"
                                                                 MaxHeight="120"
                                                                 Visibility="{Binding IsFlagsEnum, Converter={StaticResource BoolToVisibilityConverter}}">
                                                            <ListBox.ItemTemplate>
                                                                <DataTemplate>
                                                                    <CheckBox Content="{Binding DisplayName}"
                                                                              IsChecked="{Binding IsChecked}"
                                                                              Foreground="{DynamicResource NodifyEditor.ForegroundBrush}"
                                                                              Margin="2" />
                                                                </DataTemplate>
                                                            </ListBox.ItemTemplate>
                                                            <ListBox.ItemContainerStyle>
                                                                <Style TargetType="ListBoxItem">
                                                                    <Setter Property="Background" Value="Transparent"/>
                                                                    <Setter Property="Template">
                                                                        <Setter.Value>
                                                                            <ControlTemplate TargetType="ListBoxItem">
                                                                                <ContentPresenter/>
                                                                            </ControlTemplate>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </Style>
                                                            </ListBox.ItemContainerStyle>
                                                        </ListBox>
                                                    </Grid>
                                                    
                                                    <!-- Basic Type Collection (spans full width) -->
                                                    <Border BorderBrush="{DynamicResource NodifyEditor.SelectionRectangleStroke}"
                                                            BorderThickness="1"
                                                            Background="{DynamicResource Node.BackgroundBrush}"
                                                            Padding="3"
                                                            Visibility="{Binding IsBasicCollection, Converter={StaticResource BoolToVisibilityConverter}}">
                                                        <StackPanel>
                                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                                                <Button Content="+"
                                                                        Command="{Binding AddCollectionItemCommand}"
                                                                        Width="20" Height="20"
                                                                        Padding="0"
                                                                        Margin="0,0,2,0"
                                                                        Background="{DynamicResource Node.BackgroundBrush}"
                                                                        Foreground="{DynamicResource NodifyEditor.ForegroundBrush}"
                                                                        BorderBrush="{DynamicResource NodifyEditor.SelectionRectangleStroke}"/>
                                                                <TextBlock Text="{Binding CollectionItems.Count}"
                                                                           MinWidth="20"
                                                                           TextAlignment="Center"
                                                                           VerticalAlignment="Center"
                                                                           Foreground="{DynamicResource NodifyEditor.ForegroundBrush}"/>
                                                                <TextBlock Text=" items"
                                                                           VerticalAlignment="Center"
                                                                           Margin="2,0,0,0"
                                                                           Foreground="{DynamicResource NodifyEditor.ForegroundBrush}"/>
                                                            </StackPanel>
                                                            <ItemsControl ItemsSource="{Binding CollectionItems}"
                                                                          MaxHeight="120">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Grid Margin="0,2">
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="Auto"/>
                                                                                <ColumnDefinition Width="*"/>
                                                                                <ColumnDefinition Width="Auto"/>
                                                                            </Grid.ColumnDefinitions>
                                                                            
                                                                            <TextBlock Grid.Column="0"
                                                                                       Text="{Binding Index}"
                                                                                       Margin="0,0,5,0"
                                                                                       VerticalAlignment="Center"
                                                                                       Foreground="{DynamicResource NodifyEditor.ForegroundBrush}"/>
                                                                            
                                                                            <TextBox Grid.Column="1"
                                                                                     Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                                                     Background="{DynamicResource Node.BackgroundBrush}"
                                                                                     Foreground="{DynamicResource NodifyEditor.ForegroundBrush}"
                                                                                     BorderBrush="{DynamicResource NodifyEditor.SelectionRectangleStroke}"
                                                                                     Padding="2,1"
                                                                                     MinWidth="50"/>
                                                                            
                                                                            <Button Grid.Column="2"
                                                                                    Content="-"
                                                                                    Command="{Binding DataContext.RemoveCollectionItemCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                                    CommandParameter="{Binding Index}"
                                                                                    Width="20" Height="20"
                                                                                    Padding="0"
                                                                                    Margin="2,0,0,0"
                                                                                    Background="{DynamicResource Node.BackgroundBrush}"
                                                                                    Foreground="{DynamicResource NodifyEditor.ForegroundBrush}"
                                                                                    BorderBrush="{DynamicResource NodifyEditor.SelectionRectangleStroke}"/>
                                                                        </Grid>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>
                                                    </Border>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </nodify:Node.ContentTemplate>
                    </nodify:Node>
                </DataTemplate>
            </nodify:NodifyEditor.ItemTemplate>

            <nodify:NodifyEditor.ConnectionTemplate>
                <DataTemplate DataType="{x:Type local:ConnectionViewModel}">
                    <nodify:LineConnection Source="{Binding Source.Anchor}"
                                           Target="{Binding Target.Anchor}"
                                           Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=nodify:NodifyEditor}}"
                                           MouseLeftButtonDown="LineConnection_MouseLeftButtonDown">
                        <nodify:LineConnection.Style>
                            <Style TargetType="{x:Type nodify:LineConnection}"
                                   BasedOn="{StaticResource {x:Type nodify:LineConnection}}">
                                <Setter Property="Stroke">
                                    <Setter.Value>
                                        <Binding Path="Target.ConnectorTypeName" Converter="{StaticResource TypeColorConverter}" />
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Fill">
                                    <Setter.Value>
                                        <Binding Path="Target.ConnectorTypeName" Converter="{StaticResource TypeColorConverter}" />
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </nodify:LineConnection.Style>
                        <nodify:LineConnection.ContextMenu>
                            <ContextMenu DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}"
                                         Background="{DynamicResource NodifyEditor.BackgroundBrush}"
                                         Foreground="{DynamicResource NodifyEditor.ForegroundBrush}">
                                <MenuItem Header="Delete Connection" 
                                          Command="{Binding DeleteConnectionCommand}"
                                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          Style="{StaticResource ThemedMenuItem}" />
                            </ContextMenu>
                        </nodify:LineConnection.ContextMenu>
                    </nodify:LineConnection>
                </DataTemplate>
            </nodify:NodifyEditor.ConnectionTemplate>

            <nodify:NodifyEditor.PendingConnectionTemplate>
                <DataTemplate DataType="{x:Type local:PendingConnectionViewModel}">
                    <nodify:PendingConnection StartedCommand="{Binding StartCommand}"
                                              CompletedCommand="{Binding FinishCommand}"
                                              AllowOnlyConnectors="True" />
                </DataTemplate>
            </nodify:NodifyEditor.PendingConnectionTemplate>

        </nodify:NodifyEditor>

        <!-- Large Grid Background Layer -->
        <Grid Grid.Row="2" Grid.Column="2"
              Background="{StaticResource LargeGridLinesDrawingBrush}"
              IsHitTestVisible="False"
              Panel.ZIndex="-1" />

        <!-- GridSplitter -->
        <GridSplitter Grid.Row="2" Grid.Column="3" 
                      Width="5" 
                      HorizontalAlignment="Stretch" 
                      VerticalAlignment="Stretch"
                      Background="{DynamicResource NodifyEditor.ForegroundBrush}"
                      Visibility="{Binding SelectedTab.EditorViewModel.SelectedNodes.Count, Converter={StaticResource CollectionCountToVisibilityConverter}}" />

        <!-- Property Panel - Only visible when exactly one node is selected -->
        <Border Grid.Row="2" Grid.Column="4"
                BorderBrush="{DynamicResource NodifyEditor.ForegroundBrush}" 
                BorderThickness="2,0,0,0" 
                Background="{DynamicResource NodifyEditor.BackgroundBrush}"
                Visibility="{Binding SelectedTab.EditorViewModel.SelectedNodes.Count, Converter={StaticResource CollectionCountToVisibilityConverter}}">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" 
                           Text="Properties" 
                           FontWeight="Bold" 
                           Margin="10" 
                           FontSize="14"
                           Foreground="{DynamicResource NodifyEditor.ForegroundBrush}"/>

                <ScrollViewer Grid.Row="1" 
                              VerticalScrollBarVisibility="Auto"
                              Background="{DynamicResource NodifyEditor.BackgroundBrush}">
                    <ItemsControl ItemsSource="{Binding SelectedTab.EditorViewModel.SelectedNodeProperties}" Margin="10,0,10,10">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,5,0,5">
                                    <TextBlock Text="{Binding Name}" 
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource NodifyEditor.ForegroundBrush}" />

                                    <!-- String -->
                                    <TextBox Text="{Binding StringValue, UpdateSourceTrigger=PropertyChanged}" 
                                             Margin="0,2,0,0"
                                             Background="{DynamicResource Node.BackgroundBrush}"
                                             Foreground="{DynamicResource NodifyEditor.ForegroundBrush}"
                                             BorderBrush="{DynamicResource NodifyEditor.SelectionRectangleStroke}"
                                             TextWrapping="Wrap"
                                             AcceptsReturn="True"
                                             MinHeight="24"
                                             MaxHeight="150"
                                             VerticalScrollBarVisibility="Auto"
                                             Visibility="{Binding IsString, Converter={StaticResource BoolToVisibilityConverter}}" />

                                    <!-- Boolean -->
                                    <CheckBox IsChecked="{Binding BoolValue}" 
                                              Margin="0,2,0,0"
                                              Foreground="{DynamicResource NodifyEditor.ForegroundBrush}"
                                              Visibility="{Binding IsBool, Converter={StaticResource BoolToVisibilityConverter}}" />

                                    <!-- Integer -->
                                    <TextBox Text="{Binding IntValue, UpdateSourceTrigger=PropertyChanged}" 
                                             Margin="0,2,0,0"
                                             Background="{DynamicResource Node.BackgroundBrush}"
                                             Foreground="{DynamicResource NodifyEditor.ForegroundBrush}"
                                             BorderBrush="{DynamicResource NodifyEditor.SelectionRectangleStroke}"
                                             PreviewTextInput="NumericTextBox_PreviewTextInput"
                                             Visibility="{Binding IsInt, Converter={StaticResource BoolToVisibilityConverter}}" />

                                    <!-- Double -->
                                    <TextBox Text="{Binding DoubleValue, UpdateSourceTrigger=PropertyChanged}" 
                                             Margin="0,2,0,0"
                                             Background="{DynamicResource Node.BackgroundBrush}"
                                             Foreground="{DynamicResource NodifyEditor.ForegroundBrush}"
                                             BorderBrush="{DynamicResource NodifyEditor.SelectionRectangleStroke}"
                                             PreviewTextInput="DecimalTextBox_PreviewTextInput"
                                             Visibility="{Binding IsDouble, Converter={StaticResource BoolToVisibilityConverter}}" />

                                    <!-- Float -->
                                    <TextBox Text="{Binding FloatValue, UpdateSourceTrigger=PropertyChanged}" 
                                             Margin="0,2,0,0"
                                             Background="{DynamicResource Node.BackgroundBrush}"
                                             Foreground="{DynamicResource NodifyEditor.ForegroundBrush}"
                                             BorderBrush="{DynamicResource NodifyEditor.SelectionRectangleStroke}"
                                             PreviewTextInput="DecimalTextBox_PreviewTextInput"
                                             Visibility="{Binding IsFloat, Converter={StaticResource BoolToVisibilityConverter}}" />

                                    <!-- Enum -->
                                    <ComboBox ItemsSource="{Binding EnumValues}"
                                              SelectedItem="{Binding SelectedEnumValue}"
                                              Margin="0,2,0,0"
                                              Style="{StaticResource ThemedComboBox}"
                                              ItemContainerStyle="{StaticResource ThemedComboBoxItem}"
                                              Visibility="{Binding IsRegularEnum, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    
                                    <!-- Flags Enum (Multi-select) -->
                                    <ListBox ItemsSource="{Binding FlagsEnumItems}"
                                             Background="{DynamicResource Node.BackgroundBrush}"
                                             BorderBrush="{DynamicResource NodifyEditor.SelectionRectangleStroke}"
                                             BorderThickness="1"
                                             MaxHeight="120"
                                             Visibility="{Binding IsFlagsEnum, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <CheckBox Content="{Binding DisplayName}"
                                                          IsChecked="{Binding IsChecked}"
                                                          Foreground="{DynamicResource NodifyEditor.ForegroundBrush}"
                                                          Margin="2" />
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ListBoxItem">
                                                            <ContentPresenter/>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                    </ListBox>
                                    
                                    <!-- Basic Type Collection -->
                                    <Border BorderBrush="{DynamicResource NodifyEditor.SelectionRectangleStroke}"
                                            BorderThickness="1"
                                            Background="{DynamicResource Node.BackgroundBrush}"
                                            Padding="5"
                                            Margin="0,2,0,0"
                                            Visibility="{Binding IsBasicCollection, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                                <Button Content="+"
                                                        Command="{Binding AddCollectionItemCommand}"
                                                        Width="24" Height="24"
                                                        Padding="0"
                                                        Margin="0,0,5,0"
                                                        Background="{DynamicResource Node.BackgroundBrush}"
                                                        Foreground="{DynamicResource NodifyEditor.ForegroundBrush}"
                                                        BorderBrush="{DynamicResource NodifyEditor.SelectionRectangleStroke}"/>
                                                <TextBlock Text="{Binding CollectionItems.Count}"
                                                           MinWidth="20"
                                                           TextAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource NodifyEditor.ForegroundBrush}"/>
                                                <TextBlock Text=" items"
                                                           VerticalAlignment="Center"
                                                           Margin="2,0,0,0"
                                                           Foreground="{DynamicResource NodifyEditor.ForegroundBrush}"/>
                                            </StackPanel>
                                            <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                                                <ItemsControl ItemsSource="{Binding CollectionItems}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid Margin="0,3">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                
                                                                <TextBlock Grid.Column="0"
                                                                           Text="{Binding Index}"
                                                                           Margin="0,0,8,0"
                                                                           VerticalAlignment="Center"
                                                                           Foreground="{DynamicResource NodifyEditor.ForegroundBrush}"/>
                                                                
                                                                <TextBox Grid.Column="1"
                                                                         Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                                         Background="{DynamicResource Node.BackgroundBrush}"
                                                                         Foreground="{DynamicResource NodifyEditor.ForegroundBrush}"
                                                                         BorderBrush="{DynamicResource NodifyEditor.SelectionRectangleStroke}"
                                                                         Padding="3,2"
                                                                         MinWidth="80"/>
                                                                
                                                                <Button Grid.Column="2"
                                                                        Content="-"
                                                                        Command="{Binding DataContext.RemoveCollectionItemCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                        CommandParameter="{Binding Index}"
                                                                        Width="24" Height="24"
                                                                        Padding="0"
                                                                        Margin="5,0,0,0"
                                                                        Background="{DynamicResource Node.BackgroundBrush}"
                                                                        Foreground="{DynamicResource NodifyEditor.ForegroundBrush}"
                                                                        BorderBrush="{DynamicResource NodifyEditor.SelectionRectangleStroke}"/>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>